rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.currentLevel is int
        && request.resource.data.currentLevel >= 1
        && request.resource.data.totalScore is int
        && request.resource.data.totalScore >= 0;
    }

    match /users/{uid}/levels/{levelId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
        && request.resource.data.level is int
        && request.resource.data.level >= 1
        && request.resource.data.stars is int
        && request.resource.data.stars >= 0
        && request.resource.data.stars <= 3
        && request.resource.data.highScore is int
        && request.resource.data.highScore >= 0;
    }

    match /referrals/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if false;
    }
  }
}
